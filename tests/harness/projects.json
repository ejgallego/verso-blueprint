{
  "version": 1,
  "projects": [
    {
      "id": "project-template",
      "description": "In-repo starter Blueprint template rendered as a small reference site.",
      "source": {
        "kind": "in_repo_example",
        "project_root": "project_template"
      },
      "build_command": ["lake", "build"],
      "generate_command": ["lake", "exe", "blueprint-gen", "--output", "{output_dir}"],
      "site_subdir": "html-multi"
    },
    {
      "id": "noperthedron",
      "description": "Mathlib-heavy external blueprint example with browser and panel regressions.",
      "source": {
        "kind": "git_checkout",
        "repository": "https://github.com/ejgallego/verso-noperthedron.git",
        "ref": "d2b2c3db1f54a028bf56083d1d0cf7bf709b21c2",
        "project_root": "."
      },
      "build_command": ["lake", "build"],
      "generate_command": ["lake", "exe", "blueprint-gen", "--output", "{output_dir}"],
      "site_subdir": "html-multi",
      "validation": {
        "panel_regression_script": "tests/harness/noperthedron/check_blueprint_code_panels.py",
        "browser_tests_path": "tests/browser"
      }
    },
    {
      "id": "spherepackingblueprint",
      "description": "External blueprint example without project-specific browser regressions.",
      "source": {
        "kind": "git_checkout",
        "repository": "https://github.com/ejgallego/verso-sphere-packing.git",
        "ref": "e065a7306dda790fce6cfe688078d091369b3deb",
        "project_root": "."
      },
      "build_command": ["lake", "build"],
      "generate_command": ["lake", "exe", "blueprint-gen", "--output", "{output_dir}"],
      "site_subdir": "html-multi"
    }
  ]
}
