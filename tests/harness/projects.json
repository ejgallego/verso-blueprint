{
  "version": 1,
  "projects": [
    {
      "id": "project-template",
      "description": "In-repo starter Blueprint template rendered as a small reference site.",
      "source": {
        "kind": "in_repo_example",
        "project_root": "project_template"
      },
      "build_command": ["lake", "build"],
      "generate_command": ["lake", "exe", "blueprint-gen", "--output", "{output_dir}"],
      "site_subdir": "html-multi"
    },
    {
      "id": "noperthedron",
      "description": "Mathlib-heavy external blueprint example kept for generation coverage.",
      "source": {
        "kind": "git_checkout",
        "repository": "https://github.com/ejgallego/verso-noperthedron.git",
        "ref": "2c3ccab38887408931c8188709e004ffa18a70b5",
        "project_root": "."
      },
      "build_command": ["lake", "build"],
      "generate_command": ["lake", "exe", "blueprint-gen", "--output", "{output_dir}"],
      "site_subdir": "html-multi"
    },
    {
      "id": "spherepackingblueprint",
      "description": "External blueprint example without project-specific browser regressions.",
      "source": {
        "kind": "git_checkout",
        "repository": "https://github.com/ejgallego/verso-sphere-packing.git",
        "ref": "accaa9a2c0ca518040f0b3a393f3edb65bc3dc96",
        "project_root": "."
      },
      "build_command": ["lake", "build"],
      "generate_command": ["lake", "exe", "blueprint-gen", "--output", "{output_dir}"],
      "site_subdir": "html-multi"
    },
    {
      "id": "verso-flt",
      "description": "External FLT blueprint integration layer with an FLT submodule checkout.",
      "source": {
        "kind": "git_checkout",
        "repository": "https://github.com/ejgallego/verso-flt.git",
        "ref": "e92dcaa0a7e692815f5d9e2ab2b5b89a07553dbf",
        "project_root": "."
      },
      "prepare_command": [
        "git",
        "-c",
        "url.https://github.com/.insteadOf=git@github.com:",
        "-c",
        "url.https://github.com/.insteadOf=ssh://git@github.com/",
        "submodule",
        "update",
        "--init",
        "--depth",
        "1",
        "FLT"
      ],
      "build_command": ["lake", "build", "blueprint-gen"],
      "generate_command": ["lake", "exe", "blueprint-gen", "--output", "{output_dir}"],
      "site_subdir": "html-multi"
    }
  ]
}
